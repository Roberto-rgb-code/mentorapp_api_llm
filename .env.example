# .env.example
# La app Next (mentoria) llama a esta API; la key de OpenAI solo vive aquí.

# Clave API de OpenAI (usada por diagnóstico general, profundo, emergencia, documentos)
OPENAI_API_KEY=

# Clave API de xAI (Grok) - el chatbot usa Grok primero si está configurada
XAI_API_KEY=
# Opcional: modelo xAI (por defecto grok-2)
# XAI_MODEL_NAME=grok-2

